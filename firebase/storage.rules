rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDoc().data;
    }

    function userRole() {
      return userData().role;
    }

    function linkedStudentIds() {
      return signedIn() && userData().linked_student_ids is list
        ? userData().linked_student_ids
        : [];
    }

    function canReadStudent(studentId) {
      return signedIn() && (
        userRole() == "admin" ||
        studentId in linkedStudentIds()
      );
    }

    function canWriteStudentEvidence(studentId) {
      return signedIn() && (
        userRole() == "admin" ||
        userRole() == "teacher" ||
        userRole() == "student" && studentId in linkedStudentIds()
      );
    }

    match /students/{studentId}/evidence/{date}/{fileName} {
      allow read: if canReadStudent(studentId);
      allow create, update: if canWriteStudentEvidence(studentId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if signedIn() && (
        userRole() == "admin" ||
        userRole() == "teacher"
      );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
