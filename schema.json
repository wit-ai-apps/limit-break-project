{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LIMIT BREAK PROJECT v1.2.0 Record",
  "type": "object",
  "required": [
    "date",
    "missionId",
    "missionTitle",
    "subject",
    "course",
    "lesson",
    "part",
    "testType",
    "score",
    "understanding",
    "fatigue",
    "savedAt"
  ],
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "day": {
      "type": ["integer", "string"]
    },
    "missionId": {
      "type": "string"
    },
    "missionTitle": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "course": {
      "type": "string"
    },
    "lesson": {
      "type": "string"
    },
    "part": {
      "type": "string"
    },
    "testType": {
      "type": "string",
      "enum": ["初回確認テスト", "翌日確認テスト", "3日後確認テスト", "7日後確認テスト", "AI Check Test"]
    },
    "score": {
      "type": "string",
      "pattern": "^(100|[0-9]{1,2})$"
    },
    "checkItem": {
      "type": "string"
    },
    "levelTask": {
      "type": "string"
    },
    "understanding": {
      "type": "string",
      "enum": ["1", "2", "3", "4", "5"]
    },
    "fatigue": {
      "type": "string",
      "enum": ["1", "2", "3", "4", "5"]
    },
    "mistakeReason": {
      "type": "string"
    },
    "privateNote": {
      "type": "string"
    },
    "savedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
